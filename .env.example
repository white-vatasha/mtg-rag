SECRET_KEY=generate-a-long-random-string
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=300
AUTO_INDEX_ON_STARTUP=true
AUTO_DOWNLOAD_CARDS=false
ATOMIC_CARDS_URL=https://mtgjson.com/api/v5/AtomicCards.json
OLLAMA_WAIT_SECONDS=300
INDEX_DECKS_ON_STARTUP=true

# Datadog — API key from https://app.datadoghq.com/organization-settings/api-keys
# Required for ./scripts/datadog-k8s-setup.sh (never commit .env)
# DD_API_KEY=

# Local tracing (optional — requires agent at DD_AGENT_HOST, default 127.0.0.1)
DD_TRACE_ENABLED=false
DD_METRICS_ENABLED=false
DD_LOGS_JSON=true
DD_LOGS_INJECTION=true
DD_SERVICE=mtg-rag-api
DD_ENV=development
DD_VERSION=0.1.0
DD_AGENT_HOST=127.0.0.1
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125
LOG_LEVEL=INFO
